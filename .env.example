# ReadyHost Website — Environment Variables
#
# COPY THIS FILE TO .env.local FOR LOCAL DEV (do NOT commit .env.local).
# In production, set these as Vercel Project → Settings → Environment Variables.
#
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Anthropic API key for the embedded AI chat (api/chat.js)
# Get one at: https://console.anthropic.com/settings/keys
# ⚠ NEVER prefix this with REACT_APP_ or VITE_ — that would expose it to the
# browser. It MUST stay server-side only (the Vercel Function reads it).
ANTHROPIC_API_KEY=sk-ant-api03-...

# OPTIONAL — override the Claude model (defaults to claude-sonnet-4-20250514)
# Cheaper/faster: claude-haiku-4-5-20251001
# Latest sonnet:  claude-sonnet-4-6
# READYHOST_MODEL=claude-sonnet-4-20250514
